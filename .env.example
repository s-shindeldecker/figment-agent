# Looker / Tier 1
# Mode priority: LOOKER_EXPORT_PATH (file) → SNOWFLAKE_ACCOUNT (direct SQL) → Looker API

# File mode (current): export CSV from your Look and set this path
LOOKER_EXPORT_PATH=data/looker_export.csv

# Snowflake mode: unset LOOKER_EXPORT_PATH and fill these in.
# Runs _SNOWFLAKE_SQL directly against the data warehouse, bypassing Looker entirely.
# Install the connector: pip install "figment-agent[snowflake]"
# SNOWFLAKE_ACCOUNT=xy12345.us-east-1          # account identifier (no .snowflakecomputing.com)
# SNOWFLAKE_USER=your_username
# SNOWFLAKE_WAREHOUSE=YOUR_WAREHOUSE
# SNOWFLAKE_DATABASE=YOUR_DATABASE             # must contain DATAMART + STG + SALESFORCE_SRC schemas
# SNOWFLAKE_SCHEMA=DATAMART                    # optional, default DATAMART
# SNOWFLAKE_ROLE=YOUR_ROLE                     # optional
#
# Auth — key-pair (recommended, takes priority over password):
#   Generate: openssl genrsa 2048 | openssl pkcs8 -topk8 -nocrypt -out ~/.ssh/snowflake_figment_rsa.p8
#   Register: ALTER USER your_username SET RSA_PUBLIC_KEY='<public key contents, no header/footer>';
# SNOWFLAKE_PRIVATE_KEY_PATH=~/.ssh/snowflake_figment_rsa.p8
# SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=            # only needed if key was generated with -passout
#
# Auth — password fallback (used only if SNOWFLAKE_PRIVATE_KEY_PATH is not set):
# SNOWFLAKE_PASSWORD=your_password

# Looker API mode (future): unset both above and fill these in
LOOKER_CLIENT_ID=...
LOOKER_CLIENT_SECRET=...
LOOKER_BASE_URL=https://launchdarkly.cloud.looker.com

# Wisdom MCP (Enterpret) — Tier 2. Cypher-only: execute_cypher_query (no prose / search path).
# https://helpcenter.enterpret.com/en/articles/12665166-wisdom-mcp-server
# The runner calls initialize_wisdom once per MCP session (Enterpret recommends this).
WISDOM_AUTH_TOKEN=...
# Inspect graph schema: python bootstrap/wisdom_get_schema.py
# Optional; defaults to https://wisdom-api.enterpret.com/server/mcp
WISDOM_SERVER_URL=
# Optional: override Cypher tool name (default execute_cypher_query)
# WISDOM_TIER2_TOOL=execute_cypher_query
#
# Job keys (logging / env): e100-wisdom-prompt-competitive-displacement,
# e100-wisdom-prompt-switching-intent (see agents/wisdom_prompts.py).
#
# Optional: parallel Wisdom MCP sessions. Default sequential.
# WISDOM_TIER2_PARALLEL=1
#
# Cypher: required for every Tier-2 job — from config/wisdom_cypher.yaml, per-key LaunchDarkly
# JSON flags, and/or env. Competitive + switching each run two queries (Gong, Zendesk map keys).
# One env string overrides the whole job: WISDOM_CYPHER_COMPETITIVE_DISPLACEMENT,
# WISDOM_CYPHER_SWITCHING_INTENT. Global: WISDOM_CYPHER.
# Skip repo YAML only: WISDOM_DISABLE_EMBEDDED_CYPHER=1 (LD can still supply Cypher)
#
# LaunchDarkly (optional): one JSON flag per wisdom map key. Project: figment-e-100-agent.
# Install: pip install "figment-agent[launchdarkly]"
# LD_SDK_KEY=...                    # Server-side SDK key from figment-e-100-agent
# LD_PROJECT_KEY=figment-e-100-agent # Recommended; context attribute projectKey for targeting
# LD_ENV_KEY=...                    # Optional; context attribute environmentKey
# LD_CONTEXT_KEY=figment-e100       # Optional evaluation context key (default figment-e100)
# Aliases: LAUNCHDARKLY_SDK_KEY, LAUNCHDARKLY_CONTEXT_KEY
#
# Per-key flag env overrides (suffix = map key uppercased, e.g. COMPETITIVE_DISPLACEMENT_GONG):
# LD_FLAG_CYPHER_COMPETITIVE_DISPLACEMENT_GONG=figment-wisdom-cypher-competitive-displacement-gong
# (defaults match agents.ld_wisdom_config._DEFAULT_LD_FLAG_KEY_BY_MAP_KEY)
#
# Each flag variation: JSON object with string field cypher, statement, or query, e.g.
#   {"cypher": "MATCH (n) RETURN n LIMIT 1"}
#
# WISDOM_DISABLE_LD_CYPHER=1        # Skip all LD Cypher reads
#
# Tier-2 console instrumentation (optional). String LD flag default:
#   figment-agent-tier2-log-verbosity  — values: off | basic | debug | monitor
#   (or JSON {"level":"debug"}). Override flag key: LD_FLAG_LOG_VERBOSITY
# Env wins when set (local / CI without LD):
# WISDOM_TIER2_LOG_VERBOSITY=basic   # flag keys + MCP row counts per Cypher call
# WISDOM_TIER2_LOG_VERBOSITY=debug   # + per Cypher LD evaluation detail
# WISDOM_TIER2_LOG_VERBOSITY=monitor # + one JSON summary line (figment_event=tier2_wisdom_summary)
# WISDOM_DISABLE_LD_LOG_VERBOSITY=1  # ignore LD for verbosity (stay off unless env set)
#
# E100 prioritizer (optional LLM): default tries LaunchDarkly agent AI Config, then merge_and_score.
# Install: pip install "figment-agent[launchdarkly]"  (includes launchdarkly-server-sdk-ai)
# E100_PRIORITIZER_MODE=llm          # default if unset — try LLM, fallback deterministic
# E100_PRIORITIZER_MODE=deterministic # never call the LLM (merge_and_score only)
# E100_PRIORITIZER_AI_CONFIG_KEY=e100-prioritizer   # agent-mode AI Config key in LaunchDarkly
# ANTHROPIC_API_KEY=...              # for httpx Messages API when ldai provider packages are absent
# E100_PRIORITIZER_ANTHROPIC_TIMEOUT_SEC=900   # httpx read timeout (seconds); large merges can be slow
# E100_PRIORITIZER_MAX_OUTPUT_TOKENS=64000     # Anthropic max_tokens (default 64000); raise if JSON truncates
# E100_PRIORITIZER_DEBUG=1                     # traceback on model failure; model-output preview if JSON parse fails
# E100_PRIORITIZER_LOG_PROMPT=1                # print truncated system + user previews before Anthropic call
# E100_PRIORITIZER_PROMPT_LOG_PATH=/tmp/e100_prioritizer_prompt.txt  # write full system + user (UTF-8) to this file
# E100_PRIORITIZER_INCLUDE_EXTRAS_IN_PROMPT=1  # include looker/wisdom/tier3 *_extras in LLM JSON (large; default off)
#
# LaunchDarkly AI Config + Anthropic — completion-mode smoke script only (not run.py):
#   pip install "figment-agent[launchdarkly-ai]"
#   python scripts/ld_prioritizer_smoke.py
# LD_PRIORITIZER_AI_CONFIG_KEY — completion config key for the script (template {{accounts_json}}).
# LD_SDK_KEY / LD_CONTEXT_KEY / LD_PROJECT_KEY / LD_ENV_KEY — same as Tier-2 LD block.

# Tier 3 — allowlisted web fetch (config/tier3_sources.yaml). Default off.
# TIER3_WEB_ENABLED=1

# Google Sheets
GOOGLE_SHEET_ID=...
# Tab titles are hardcoded in outputs/sheets_writer.py (_WORKSHEET_TITLES); rename tabs in Sheets
# to match (e.g. E100 Summary, E100 Tier 1–3, E100 Changelog) or edit that dict in code.
#
# Optional fourth tab: quota summary (same list as console / Slack; tier tabs stay full lists):
# E100_WRITE_MERGED_MASTER=1
# Full merged list (no 50/25/25 cap): E100_SUMMARY_USE_FULL_MERGE=1
# Optional quota overrides: E100_SUMMARY_TIER1_MAX=50 E100_SUMMARY_TIER2_MAX=25 E100_SUMMARY_TIER3_MAX=25
#
# Run-to-run diff: baseline saved to data/e100_last_sheet_snapshot.json (gitignored); Changelog tab.
# Optional: append a Δ column (new / changed) on each data tab — E100_SHEET_MARK_CHANGES=1
# Optional: snapshot path (default data/e100_last_sheet_snapshot.json) — E100_SHEET_SNAPSHOT_PATH=
# Optional: path to service account JSON (default: config/google_service_account.json).
# GCP often names keys e.g. config/figment-e100-writer-….json
# GOOGLE_SERVICE_ACCOUNT_FILE=config/figment-e100-writer-aabe7d1b2311.json
# GOOGLE_APPLICATION_CREDENTIALS is also accepted (same semantics).

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
