# LaunchDarkly
LD_SDK_KEY=sdk-...
LD_API_KEY=api-...
LD_PROJECT_KEY=default
LD_ENV_KEY=production

# Looker
# File mode (current): export CSV from your Look and set this path
LOOKER_EXPORT_PATH=data/looker_export.csv
# API mode (future): unset LOOKER_EXPORT_PATH and fill these in instead
LOOKER_CLIENT_ID=...
LOOKER_CLIENT_SECRET=...
LOOKER_BASE_URL=https://launchdarkly.cloud.looker.com

# Anthropic — required for the prioritizer LLM when ldai provider packages are not used.
ANTHROPIC_API_KEY=sk-ant-...

# E100 prioritizer: AI Config key (agent mode) evaluated via LD_SDK_KEY + context user/e100-agent.
# E100_PRIORITIZER_AI_CONFIG_KEY=e100-prioritizer
# Disable the AI Config in LaunchDarkly to use deterministic merge_and_score instead.

# Wisdom MCP (Enterpret) — Tier 2. Auth token from Settings → Wisdom MCP.
# https://helpcenter.enterpret.com/en/articles/12665166-wisdom-mcp-server
# The runner calls initialize_wisdom once per MCP session (Enterpret recommends this).
# For tabular account rows, prefer WISDOM_CYPHER_* + execute_cypher_query; search_knowledge_graph
# often returns exploration metadata or prose rather than account-shaped JSON.
WISDOM_AUTH_TOKEN=...
# Optional; defaults to https://wisdom-api.enterpret.com/server/mcp
WISDOM_SERVER_URL=
# Optional: override tool (default search_knowledge_graph)
# WISDOM_TIER2_TOOL=search_knowledge_graph
#
# Tier 2 prompt **bodies** are LaunchDarkly **string multivariate** flags (same project as LD_SDK_KEY).
# Bootstrap (REST, same as MCP create-feature-flag):
#   python bootstrap/create_wisdom_string_flags.py
# Or: Cursor LaunchDarkly MCP → create-feature-flag using --print-mcp-hints payloads.
# Flag keys:
#   e100-wisdom-prompt-competitive-displacement
#   e100-wisdom-prompt-switching-intent
#   e100-wisdom-prompt-eppo-coverage
# Each flag uses two variations: "empty" ("") and "production" (full prompt). Turn the flag **on**
# in the environment that matches LD_SDK_KEY so the SDK serves **production**, not empty.
# If all resolved prompts are empty or LD_SDK_KEY is unset, the runner uses
# wisdom.tier2_prompt_fallback in config/settings.yaml.
#
# Optional: parallel Wisdom MCP sessions. Default sequential.
# WISDOM_TIER2_PARALLEL=1
#
# Optional Cypher (execute_cypher_query): WISDOM_CYPHER for all jobs, or per LD flag (see
# agents.wisdom_prompts.WISDOM_CYPHER_ENV_SUFFIX_BY_FLAG_KEY):
# WISDOM_CYPHER_COMPETITIVE_DISPLACEMENT=MATCH ...
# WISDOM_CYPHER_SWITCHING_INTENT=MATCH ...
# WISDOM_CYPHER_EPPO_COVERAGE=MATCH ...
# YAML fallback uses WISDOM_CYPHER_SETTINGS_YAML or WISDOM_CYPHER.

# Google Sheets
GOOGLE_SHEET_ID=...

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
